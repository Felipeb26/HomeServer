apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: uptime-kuma-outpost
  namespace: security
spec:
  ingressClassName: nginx
  rules:
    - host: uptime.batsworks.com.br
      http:
        paths:
          - path: /outpost.goauthentik.io
            pathType: Prefix
            backend:
              service:
                name: authentik-proxy-outpost
                port:
                  number: 9000
