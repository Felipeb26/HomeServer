apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: ingress-nginx
  namespace: argocd
spec:
  project: default
  source:
    repoURL: https://kubernetes.github.io/ingress-nginx
    chart: ingress-nginx
    targetRevision: "4.12.0"
    helm:
      values: |
        controller:
          config:
            # Fix necessário no k3s — sem isso o nginx não consegue
            # ler os certificados TLS emitidos pelo cert-manager
            main-snippet: |
              user root;
          # Garante que o controller sobe no nó correto (sem hostNetwork,
          # pois o AdGuard já usa as portas de DNS via NodePort)
          hostNetwork: false
          resources:
            requests:
              memory: 256Mi
              cpu: 100m
            limits:
              memory: 512Mi
              cpu: 150m
          service:
            type: LoadBalancer
  destination:
    server: https://kubernetes.default.svc
    namespace: ingress-nginx
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
